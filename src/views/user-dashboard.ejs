<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Dashboard - <%= siteName %></title>
    <link rel="stylesheet" href="/css/dashboard-widgets.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <%- include('partials/header') %>
    
    <div class="dashboard-container">
        <div class="dashboard-header">
            <h1><i class="fas fa-user"></i> My Dashboard</h1>
            <div class="dashboard-actions">
                <button class="btn-icon" title="Cài đặt">
                    <i class="fas fa-cog"></i>
                </button>
                <button class="btn-icon" title="Làm mới">
                    <i class="fas fa-sync"></i>
                </button>
            </div>
        </div>

        <div class="widgets-grid">
            <!-- User Stats -->
            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-bookmark"></i> Đã lưu
                    </div>
                </div>
                <div class="stats-value">24</div>
                <div class="stats-label">Bài viết đã lưu</div>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-heart"></i> Yêu thích
                    </div>
                </div>
                <div class="stats-value">156</div>
                <div class="stats-label">Bài viết đã thích</div>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-comment"></i> Bình luận
                    </div>
                </div>
                <div class="stats-value">89</div>
                <div class="stats-label">Bình luận của tôi</div>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-users"></i> Theo dõi
                    </div>
                </div>
                <div class="stats-value">42</div>
                <div class="stats-label">Đang theo dõi</div>
            </div>

            <!-- Reading Activity -->
            <div class="widget widget-large chart-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-chart-line"></i> Hoạt động đọc
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="readingChart"></canvas>
                </div>
            </div>

            <!-- Quick Actions for Users -->
            <div class="widget widget-medium">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-bolt"></i> Thao tác nhanh
                    </div>
                </div>
                <div class="quick-actions-widget">
                    <button class="quick-action-btn">
                        <i class="fas fa-search"></i>
                        <span>Tìm kiếm</span>
                    </button>
                    <button class="quick-action-btn">
                        <i class="fas fa-bookmark"></i>
                        <span>Đã lưu</span>
                    </button>
                    <button class="quick-action-btn">
                        <i class="fas fa-history"></i>
                        <span>Lịch sử đọc</span>
                    </button>
                    <button class="quick-action-btn">
                        <i class="fas fa-user-cog"></i>
                        <span>Cài đặt</span>
                    </button>
                </div>
            </div>

            <!-- Reading Goals -->
            <div class="widget widget-medium">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-target"></i> Mục tiêu đọc
                    </div>
                </div>
                <div class="progress-list">
                    <div class="progress-item">
                        <div class="progress-header">
                            <span class="progress-label">Bài viết tuần này</span>
                            <span class="progress-value">8/10</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 80%"></div>
                        </div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header">
                            <span class="progress-label">Thời gian đọc</span>
                            <span class="progress-value">4.5/5 giờ</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 90%"></div>
                        </div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header">
                            <span class="progress-label">Tương tác</span>
                            <span class="progress-value">15/20</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 75%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recommended Posts -->
            <div class="widget widget-large">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-star"></i> Đề xuất cho bạn
                    </div>
                </div>
                <div class="activity-list">
                    <div class="activity-item">
                        <div class="activity-icon info">
                            <i class="fas fa-file-alt"></i>
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">10 Tips JavaScript Nâng Cao</div>
                            <div class="activity-time">Lập trình • 5 phút đọc</div>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon info">
                            <i class="fas fa-file-alt"></i>
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">React Hooks Complete Guide</div>
                            <div class="activity-time">Frontend • 8 phút đọc</div>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon info">
                            <i class="fas fa-file-alt"></i>
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">Node.js Best Practices 2026</div>
                            <div class="activity-time">Backend • 10 phút đọc</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Reading History -->
            <div class="widget widget-medium">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-history"></i> Đã đọc gần đây
                    </div>
                </div>
                <div class="activity-list">
                    <div class="activity-item">
                        <div class="activity-icon success">
                            <i class="fas fa-check"></i>
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">Hướng dẫn Node.js</div>
                            <div class="activity-time">Đã đọc • 2 giờ trước</div>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon success">
                            <i class="fas fa-check"></i>
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">React Best Practices</div>
                            <div class="activity-time">Đã đọc • 1 ngày trước</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Favorite Authors -->
            <div class="widget widget-medium">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-user-friends"></i> Tác giả yêu thích
                    </div>
                </div>
                <div class="activity-list">
                    <div class="activity-item">
                        <div class="activity-icon" style="background: none; padding: 0;">
                            <img src="/images/default-avatar.png" style="width: 36px; height: 36px; border-radius: 50%;">
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">John Doe</div>
                            <div class="activity-time">48 bài viết • 1.2K followers</div>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon" style="background: none; padding: 0;">
                            <img src="/images/default-avatar.png" style="width: 36px; height: 36px; border-radius: 50%;">
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">Jane Smith</div>
                            <div class="activity-time">42 bài viết • 980 followers</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Achievements -->
            <div class="widget widget-full">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-trophy"></i> Thành tích của tôi
                    </div>
                </div>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1rem;">
                    <div style="text-align: center; padding: 1rem; background: var(--bg-secondary); border-radius: 8px;">
                        <div style="font-size: 2rem; margin-bottom: 0.5rem;">🎯</div>
                        <div style="font-weight: 600; margin-bottom: 0.25rem;">Người đọc tích cực</div>
                        <div style="font-size: 0.875rem; color: var(--text-secondary);">Đọc 100 bài viết</div>
                    </div>
                    <div style="text-align: center; padding: 1rem; background: var(--bg-secondary); border-radius: 8px;">
                        <div style="font-size: 2rem; margin-bottom: 0.5rem;">💬</div>
                        <div style="font-weight: 600; margin-bottom: 0.25rem;">Người bình luận</div>
                        <div style="font-size: 0.875rem; color: var(--text-secondary);">50 bình luận</div>
                    </div>
                    <div style="text-align: center; padding: 1rem; background: var(--bg-secondary); border-radius: 8px;">
                        <div style="font-size: 2rem; margin-bottom: 0.5rem;">⭐</div>
                        <div style="font-weight: 600; margin-bottom: 0.25rem;">Người ủng hộ</div>
                        <div style="font-size: 0.875rem; color: var(--text-secondary);">100 lượt thích</div>
                    </div>
                    <div style="text-align: center; padding: 1rem; background: var(--bg-secondary); border-radius: 8px; opacity: 0.5;">
                        <div style="font-size: 2rem; margin-bottom: 0.5rem;">🔒</div>
                        <div style="font-weight: 600; margin-bottom: 0.25rem;">Chuyên gia</div>
                        <div style="font-size: 0.875rem; color: var(--text-secondary);">Chưa mở khóa</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/dashboard-widgets.js"></script>
</body>
</html>
