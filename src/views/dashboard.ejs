<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - <%= siteName %></title>
    <link rel="stylesheet" href="/css/dashboard-widgets.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <%- include('partials/header') %>
    
    <div class="dashboard-container">
        <div class="dashboard-header">
            <h1>Dashboard</h1>
            <div class="dashboard-actions">
                <button class="btn-icon" title="Tùy chỉnh">
                    <i class="fas fa-cog"></i>
                </button>
                <button class="btn-icon" title="Làm mới">
                    <i class="fas fa-sync"></i>
                </button>
            </div>
        </div>

        <div class="widgets-grid">
            <!-- Stats Widgets -->
            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-eye"></i> Lượt xem
                    </div>
                </div>
                <div class="stats-value">12,543</div>
                <div class="stats-label">Tổng lượt xem</div>
                <span class="stats-change positive">
                    <i class="fas fa-arrow-up"></i> 12.5%
                </span>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-file-alt"></i> Bài viết
                    </div>
                </div>
                <div class="stats-value">48</div>
                <div class="stats-label">Tổng bài viết</div>
                <span class="stats-change positive">
                    <i class="fas fa-arrow-up"></i> 8.2%
                </span>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-comments"></i> Bình luận
                    </div>
                </div>
                <div class="stats-value">324</div>
                <div class="stats-label">Tổng bình luận</div>
                <span class="stats-change positive">
                    <i class="fas fa-arrow-up"></i> 15.3%
                </span>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-users"></i> Người theo dõi
                    </div>
                </div>
                <div class="stats-value">1,234</div>
                <div class="stats-label">Người theo dõi</div>
                <span class="stats-change positive">
                    <i class="fas fa-arrow-up"></i> 5.7%
                </span>
            </div>

            <!-- Chart Widget -->
            <div class="widget widget-large chart-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-chart-line"></i> Lượt xem theo thời gian
                    </div>
                    <div class="widget-actions">
                        <button class="widget-action-btn">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="viewsChart"></canvas>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="widget widget-medium">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-bolt"></i> Thao tác nhanh
                    </div>
                </div>
                <div class="quick-actions-widget">
                    <button class="quick-action-btn">
                        <i class="fas fa-plus"></i>
                        <span>Bài viết mới</span>
                    </button>
                    <button class="quick-action-btn">
                        <i class="fas fa-image"></i>
                        <span>Tải ảnh lên</span>
                    </button>
                    <button class="quick-action-btn">
                        <i class="fas fa-users"></i>
                        <span>Quản lý người dùng</span>
                    </button>
                    <button class="quick-action-btn">
                        <i class="fas fa-cog"></i>
                        <span>Cài đặt</span>
                    </button>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="widget widget-large">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-clock"></i> Hoạt động gần đây
                    </div>
                </div>
                <div class="activity-list">
                    <div class="activity-item">
                        <div class="activity-icon success">
                            <i class="fas fa-check"></i>
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">Bài viết mới được xuất bản</div>
                            <div class="activity-time">5 phút trước</div>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon info">
                            <i class="fas fa-comment"></i>
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">Bình luận mới từ User123</div>
                            <div class="activity-time">15 phút trước</div>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon warning">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">Người theo dõi mới</div>
                            <div class="activity-time">1 giờ trước</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Progress Widget -->
            <div class="widget widget-medium">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-tasks"></i> Tiến độ
                    </div>
                </div>
                <div class="progress-list">
                    <div class="progress-item">
                        <div class="progress-header">
                            <span class="progress-label">Mục tiêu bài viết</span>
                            <span class="progress-value">48/50</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 96%"></div>
                        </div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header">
                            <span class="progress-label">Tương tác</span>
                            <span class="progress-value">324/500</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 65%"></div>
                        </div>
                    </div>
                    <div class="progress-item">
                        <div class="progress-header">
                            <span class="progress-label">Người theo dõi</span>
                            <span class="progress-value">1,234/2,000</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: 62%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/dashboard-widgets.js"></script>
</body>
</html>
