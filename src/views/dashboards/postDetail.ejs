<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post.title %> - Chi tiết bài viết</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; color: #333; }
        .detail-card { border-radius: 15px; border: none; box-shadow: 0 5px 25px rgba(0,0,0,0.05); background: white; }
        .post-header { border-bottom: 2px solid #f8f9fa; padding-bottom: 20px; margin-bottom: 30px; }
        .post-content-box { line-height: 1.8; font-size: 1.1rem; color: #2c3e50; white-space: pre-wrap; background: #fff; padding: 20px; border-radius: 10px; }
        .media-wrapper { border-radius: 15px; overflow: hidden; background: #000; margin-bottom: 30px; box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        video, img { width: 100%; max-height: 550px; object-fit: contain; display: block; }
        .info-label { font-size: 0.8rem; text-transform: uppercase; color: #6c757d; font-weight: bold; letter-spacing: 1px; }
        .info-value { font-weight: 600; color: #198754; }
        .slug-box { background: #e9ecef; padding: 10px 15px; border-radius: 8px; font-family: monospace; font-size: 0.9rem; }
        .comment-box { background: #f8f9fa; border-radius: 12px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #198754; }
        .comment-timestamp { font-size: 0.78rem; color: #adb5bd; }
        .comment-timestamp.edited { color: #6c757d; font-style: italic; }
    </style>
</head>
<body class="py-5">
    <div class="container">
        <div class="mb-4">
            <a href="/admin/posts" class="btn btn-white border rounded-pill px-4 shadow-sm">
                <i class="bi bi-arrow-left-circle me-2"></i>Quay lại danh sách
            </a>
        </div>

        <div class="row g-4">
            <%# ===================== CỘT TRÁI: NỘI DUNG BÀI + BÌNH LUẬN ===================== %>
            <div class="col-lg-8">

                <%# THÔNG TIN BÀI VIẾT %>
                <div class="card detail-card p-4 mb-4">
                    <div class="post-header">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-success px-3 py-2 rounded-pill">
                                <i class="bi bi-folder2-open me-1"></i>
                                <%= post.category ? post.category.name : 'Chưa phân loại' %>
                            </span>
                            <span class="text-muted small">ID: #<%= post.id %></span>
                        </div>
                        <h1 class="fw-bold text-dark mb-3"><%= post.title %></h1>
                        <div class="slug-box text-break">
                            <i class="bi bi-link-45deg"></i> <strong>Slug:</strong> <%= post.slug %>
                        </div>
                    </div>

                    <div class="media-wrapper">
                        <% if (post.video) { %>
                            <video controls poster="<%= post.image %>">
                                <source src="<%= post.video %>" type="video/mp4">
                                Trình duyệt không hỗ trợ video.
                            </video>
                        <% } else if (post.image) { %>
                            <img src="<%= post.image %>" alt="Hình ảnh">
                        <% } %>
                    </div>

                    <h5 class="fw-bold mb-3"><i class="bi bi-file-earmark-text me-2"></i>Nội dung chi tiết:</h5>
                    <div class="post-content-box border shadow-sm mb-4"><%= post.content %></div>

                    <div class="mb-2">
                        <h6 class="fw-bold"><i class="bi bi-tags"></i> Tags bài viết:</h6>
                        <% if (post.tags && post.tags.length > 0) { %>
                            <% post.tags.forEach(t => { %>
                                <span class="badge bg-success me-1">#<%= t.name %></span>
                            <% }) %>
                        <% } else { %>
                            <span class="text-muted small fst-italic">Chưa gắn thẻ tags</span>
                        <% } %>
                    </div>
                </div>

                <%# PHẦN BÌNH LUẬN %>
                <% if (post.status === 'approved') { %>
                    <div class="card detail-card p-4">
                        <h4 class="fw-bold mb-4"><i class="bi bi-chat-left-text me-2"></i>Thảo luận</h4>

                        <%# FORM THÊM BÌNH LUẬN %>
                        <form action="/comments/add" method="POST" class="mb-5">
                            <input type="hidden" name="postId" value="<%= post.id %>">
                            <div class="mb-3">
                                <textarea name="content" class="form-control" rows="3" placeholder="Sếp nghĩ gì về bài này?" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-success rounded-pill px-4">Gửi bình luận</button>
                        </form>

                        <%# DANH SÁCH BÌNH LUẬN %>
                        <div class="comment-list">
                            <% if (post.comments && post.comments.length > 0) { %>
                                <% post.comments.forEach(cmt => { %>
                                    <div class="comment-box shadow-sm" id="cmt-container-<%= cmt.id %>">

                                        <%# HEADER COMMENT: Tên + Timestamp + Nút hành động %>
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <span class="fw-bold text-success">
                                                    <i class="bi bi-person-circle me-1"></i>
                                                    <%= cmt.author ? cmt.author.name : 'Ẩn danh' %>
                                                </span>
                                                <br>
                                                <% if (cmt.updatedAt) { %>
                                                    <small class="comment-timestamp edited">
                                                        <i class="bi bi-pencil me-1"></i>Đã sửa: <%= new Date(cmt.updatedAt).toLocaleString('vi-VN') %>
                                                    </small>
                                                <% } else if (cmt.createdAt) { %>
                                                    <small class="comment-timestamp">
                                                        <i class="bi bi-clock me-1"></i><%= new Date(cmt.createdAt).toLocaleString('vi-VN') %>
                                                    </small>
                                                <% } %>
                                            </div>

                                            <%# NÚT SỬA / XÓA %>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-sm text-primary p-0" onclick="toggleEdit('<%= cmt.id %>')">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                                <% if (user.role === 'admin' || user.role === 'manager' || user.id === cmt.userId) { %>
                                                    <form action="/comments/delete/<%= cmt.id %>" method="POST" onsubmit="return confirm('Xóa nhé sếp?')">
                                                        <button type="submit" class="btn btn-sm text-danger p-0 border-0 bg-transparent">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </div>

                                        <%# NỘI DUNG COMMENT %>
                                        <p id="content-text-<%= cmt.id %>" class="mb-0 text-dark"><%= cmt.content %></p>

                                        <%# FORM SỬA COMMENT %>
                                        <form id="edit-form-<%= cmt.id %>" action="/comments/update/<%= cmt.id %>" method="POST" class="mt-2 d-none">
                                            <div class="input-group">
                                                <input type="text" name="content" class="form-control" value="<%= cmt.content %>" required>
                                                <button type="submit" class="btn btn-primary btn-sm">Lưu</button>
                                                <button type="button" class="btn btn-secondary btn-sm" onclick="toggleEdit('<%= cmt.id %>')">Hủy</button>
                                            </div>
                                        </form>

                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="text-muted text-center py-4 fst-italic">Chưa có bình luận nào. Sếp mở bát đi!</p>
                            <% } %>
                        </div>
                    </div>
                <% } else { %>
                    <div class="alert alert-warning rounded-4 border-0 shadow-sm mt-4">
                        <i class="bi bi-info-circle me-2"></i> Bài viết đang chờ duyệt. Chế độ bình luận đang tạm khóa.
                    </div>
                <% } %>

            </div>

            <%# ===================== CỘT PHẢI: THÔNG SỐ HỆ THỐNG ===================== %>
            <div class="col-lg-4">
                <div class="card detail-card p-4 sticky-top" style="top: 20px;">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Thông số hệ thống</h5>

                    <div class="mb-4">
                        <p class="info-label mb-1">Tác giả</p>
                        <p class="info-value mb-0">
                            <i class="bi bi-person-check me-1"></i>
                            <%= post.author ? post.author.name : 'Ẩn danh' %>
                        </p>
                    </div>

                    <div class="mb-4">
                        <p class="info-label mb-1">Trạng thái bài viết</p>
                        <span class="badge <%= post.status === 'pending' ? 'bg-warning text-dark' : 'bg-success' %> w-100 py-2">
                            <%= post.status === 'pending' ? 'ĐANG CHỜ DUYỆT' : 'ĐÃ CÔNG KHAI' %>
                        </span>
                    </div>

                    <div class="mb-4">
                        <p class="info-label mb-1">Ngày khởi tạo</p>
                        <p class="text-dark small mb-0">
                            <i class="bi bi-calendar3 me-2"></i><%= new Date(post.createdAt).toLocaleString('vi-VN') %>
                        </p>
                    </div>

                    <div class="card bg-light border-0 mb-4">
                        <div class="card-body d-flex justify-content-around text-center">
                            <div>
                                <div class="h4 fw-bold mb-0 text-primary"><%= post.stats ? post.stats.view_count : 0 %></div>
                                <small class="text-muted">Views</small>
                            </div>
                            <div class="border-start"></div>
                            <div>
                                <div class="h4 fw-bold mb-0 text-danger"><%= post.stats ? post.stats.like_count : 0 %></div>
                                <small class="text-muted">Likes</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <% if (post.status === 'pending' && (user.role === 'admin' || user.role === 'manager')) { %>
                            <form action="/admin/posts/approve/<%= post.id %>" method="POST">
                                <input type="hidden" name="action" value="approved">
                                <button type="submit" class="btn btn-success w-100 mb-2">
                                    <i class="bi bi-check-circle me-2"></i>Phê duyệt bài viết
                                </button>
                            </form>
                        <% } %>
                        <a href="/admin/posts/edit/<%= post.id %>" class="btn btn-outline-primary">
                            <i class="bi bi-pencil-square me-2"></i>Chỉnh sửa nội dung
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        function toggleEdit(id) {
            const text = document.getElementById(`content-text-${id}`);
            const form = document.getElementById(`edit-form-${id}`);
            if (form.classList.contains('d-none')) {
                form.classList.remove('d-none');
                text.classList.add('d-none');
            } else {
                form.classList.add('d-none');
                text.classList.remove('d-none');
            }
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
