<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - <%= siteName %></title>
    <link rel="stylesheet" href="/css/dashboard-widgets.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <%- include('../../partials/header') %>
    
    <div style="display: flex;">
        <%- include('../../partials/admin-sidebar') %>
        
        <main style="flex: 1; margin-left: 250px; padding: 2rem;">
            <div class="dashboard-container" style="max-width: 100%; margin: 0;">
                <div class="dashboard-header">
                    <h1><i class="fas fa-crown"></i> Admin Dashboard</h1>
                    <div class="dashboard-actions">
                        <button class="btn-icon" title="Tùy chỉnh">
                            <i class="fas fa-cog"></i>
                        </button>
                        <button class="btn-icon" title="Làm mới">
                            <i class="fas fa-sync"></i>
                        </button>
                        <button class="btn-icon" title="Xuất báo cáo">
                            <i class="fas fa-download"></i>
                        </button>
                    </div>
                </div>

                <div class="widgets-grid">
                    <!-- Stats Widgets -->
                    <div class="widget widget-small stats-widget">
                        <div class="widget-header">
                            <div class="widget-title">
                                <i class="fas fa-users"></i> Tổng người dùng
                            </div>
                        </div>
                        <div class="stats-value">2,543</div>
                        <div class="stats-label">Người dùng đăng ký</div>
                        <span class="stats-change positive">
                            <i class="fas fa-arrow-up"></i> 12.5%
                        </span>
                    </div>

                    <div class="widget widget-small stats-widget">
                        <div class="widget-header">
                            <div class="widget-title">
                                <i class="fas fa-file-alt"></i> Tổng bài viết
                            </div>
                        </div>
                        <div class="stats-value">1,248</div>
                        <div class="stats-label">Bài viết đã xuất bản</div>
                        <span class="stats-change positive">
                            <i class="fas fa-arrow-up"></i> 8.2%
                        </span>
                    </div>

                    <div class="widget widget-small stats-widget">
                        <div class="widget-header">
                            <div class="widget-title">
                                <i class="fas fa-comments"></i> Bình luận
                            </div>
                        </div>
                        <div class="stats-value">8,324</div>
                        <div class="stats-label">Tổng bình luận</div>
                        <span class="stats-change positive">
                            <i class="fas fa-arrow-up"></i> 15.3%
                        </span>
                    </div>

                    <div class="widget widget-small stats-widget">
                        <div class="widget-header">
                            <div class="widget-title">
                                <i class="fas fa-dollar-sign"></i> Doanh thu
                            </div>
                        </div>
                        <div class="stats-value">$12,543</div>
                        <div class="stats-label">Tháng này</div>
                        <span class="stats-change positive">
                            <i class="fas fa-arrow-up"></i> 23.7%
                        </span>
                    </div>

                    <!-- System Health -->
                    <div class="widget widget-medium">
                        <div class="widget-header">
                            <div class="widget-title">
                                <i class="fas fa-heartbeat"></i> Tình trạng hệ thống
                            </div>
                        </div>
                        <div class="progress-list">
                            <div class="progress-item">
                                <div class="progress-header">
                                    <span class="progress-label">CPU Usage</span>
                                    <span class="progress-value">45%</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 45%; background: #10b981;"></div>
                                </div>
                            </div>
                            <div class="progress-item">
                                <div class="progress-header">
                                    <span class="progress-label">Memory</span>
                                    <span class="progress-value">68%</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 68%; background: #f59e0b;"></div>
                                </div>
                            </div>
                            <div class="progress-item">
                                <div class="progress-header">
                                    <span class="progress-label">Disk Space</span>
                                    <span class="progress-value">32%</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 32%; background: #10b981;"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Admin Quick Actions -->
                    <div class="widget widget-medium">
                        <div class="widget-header">
                            <div class="widget-title">
                                <i class="fas fa-bolt"></i> Quản lý nhanh
                            </div>
                        </div>
                        <div class="quick-actions-widget">
                            <a href="/admin/users" class="quick-action-btn" style="text-decoration: none;">
                                <i class="fas fa-user-shield"></i>
                                <span>Quản lý người dùng</span>
                            </a>
                            <a href="/admin/posts" class="quick-action-btn" style="text-decoration: none;">
                                <i class="fas fa-file-alt"></i>
                                <span>Duyệt bài viết</span>
                            </a>
                            <button class="quick-action-btn">
                                <i class="fas fa-flag"></i>
                                <span>Báo cáo vi phạm</span>
                            </button>
                            <button class="quick-action-btn">
                                <i class="fas fa-cog"></i>
                                <span>Cài đặt hệ thống</span>
                            </button>
                        </div>
                    </div>

                    <!-- Recent Users -->
                    <div class="widget widget-large">
                        <div class="widget-header">
                            <div class="widget-title">
                                <i class="fas fa-user-plus"></i> Người dùng mới
                            </div>
                        </div>
                        <div class="activity-list">
                            <div class="activity-item">
                                <div class="activity-icon success">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-title">User123 đã đăng ký</div>
                                    <div class="activity-time">5 phút trước</div>
                                </div>
                            </div>
                            <div class="activity-item">
                                <div class="activity-icon success">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-title">Author456 đã đăng ký</div>
                                    <div class="activity-time">15 phút trước</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Pending Approvals -->
                    <div class="widget widget-medium">
                        <div class="widget-header">
                            <div class="widget-title">
                                <i class="fas fa-clock"></i> Chờ duyệt
                            </div>
                        </div>
                        <div class="activity-list">
                            <div class="activity-item">
                                <div class="activity-icon warning">
                                    <i class="fas fa-file-alt"></i>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-title">12 bài viết chờ duyệt</div>
                                    <div class="activity-time">Cần xem xét</div>
                                </div>
                            </div>
                            <div class="activity-item">
                                <div class="activity-icon warning">
                                    <i class="fas fa-comment"></i>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-title">8 bình luận bị báo cáo</div>
                                    <div class="activity-time">Cần kiểm tra</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
