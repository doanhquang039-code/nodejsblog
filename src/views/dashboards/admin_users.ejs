<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý người dùng - Admin</title>
    <link rel="stylesheet" href="/css/dashboard-widgets.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('../../partials/header') %>
    
    <div style="display: flex;">
        <%- include('../../partials/admin-sidebar') %>
        
        <main style="flex: 1; margin-left: 250px; padding: 2rem;">
            <div class="dashboard-container" style="max-width: 100%; margin: 0;">
                <div class="dashboard-header">
            <h1><i class="fas fa-users"></i> Quản lý người dùng</h1>
            <div class="dashboard-actions">
                <button class="btn-icon" title="Thêm người dùng">
                    <i class="fas fa-user-plus"></i>
                </button>
                <button class="btn-icon" title="Xuất Excel">
                    <i class="fas fa-file-excel"></i>
                </button>
                <button class="btn-icon" title="Làm mới">
                    <i class="fas fa-sync"></i>
                </button>
            </div>
        </div>

        <div class="widgets-grid">
            <!-- Stats -->
            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-users"></i> Tổng người dùng
                    </div>
                </div>
                <div class="stats-value">2,543</div>
                <div class="stats-label">Đã đăng ký</div>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-user-check"></i> Đang hoạt động
                    </div>
                </div>
                <div class="stats-value">1,892</div>
                <div class="stats-label">Online hôm nay</div>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-pen-fancy"></i> Tác giả
                    </div>
                </div>
                <div class="stats-value">156</div>
                <div class="stats-label">Authors</div>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-user-slash"></i> Bị khóa
                    </div>
                </div>
                <div class="stats-value">12</div>
                <div class="stats-label">Banned</div>
            </div>

            <!-- Filters & Search -->
            <div class="widget widget-full">
                <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
                    <input type="text" placeholder="Tìm kiếm người dùng..." style="flex: 1; min-width: 300px; padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 8px;">
                    <select style="padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 8px;">
                        <option>Tất cả vai trò</option>
                        <option>Admin</option>
                        <option>Author</option>
                        <option>User</option>
                    </select>
                    <select style="padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 8px;">
                        <option>Tất cả trạng thái</option>
                        <option>Đang hoạt động</option>
                        <option>Bị khóa</option>
                    </select>
                    <button style="padding: 0.75rem 1.5rem; background: var(--primary-color); color: white; border: none; border-radius: 8px; cursor: pointer;">
                        <i class="fas fa-search"></i> Tìm kiếm
                    </button>
                </div>
            </div>

            <!-- Users Table -->
            <div class="widget widget-full">
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: var(--bg-secondary); text-align: left;">
                                <th style="padding: 1rem;">
                                    <input type="checkbox">
                                </th>
                                <th style="padding: 1rem;">Người dùng</th>
                                <th style="padding: 1rem;">Email</th>
                                <th style="padding: 1rem;">Vai trò</th>
                                <th style="padding: 1rem;">Bài viết</th>
                                <th style="padding: 1rem;">Trạng thái</th>
                                <th style="padding: 1rem;">Ngày tham gia</th>
                                <th style="padding: 1rem;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr style="border-bottom: 1px solid var(--border-color);">
                                <td style="padding: 1rem;"><input type="checkbox"></td>
                                <td style="padding: 1rem;">
                                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                                        <img src="/images/default-avatar.png" style="width: 40px; height: 40px; border-radius: 50%;">
                                        <div>
                                            <strong>John Doe</strong>
                                            <div style="font-size: 0.875rem; color: var(--text-secondary);">@johndoe</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="padding: 1rem;">john@example.com</td>
                                <td style="padding: 1rem;">
                                    <span style="padding: 0.25rem 0.75rem; background: #8b5cf6; color: white; border-radius: 12px; font-size: 0.875rem;">
                                        Author
                                    </span>
                                </td>
                                <td style="padding: 1rem;">48</td>
                                <td style="padding: 1rem;">
                                    <span style="padding: 0.25rem 0.75rem; background: #10b981; color: white; border-radius: 12px; font-size: 0.875rem;">
                                        Hoạt động
                                    </span>
                                </td>
                                <td style="padding: 1rem;">15/01/2025</td>
                                <td style="padding: 1rem;">
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer;" title="Xem">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer;" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer; color: var(--danger-color);" title="Khóa">
                                        <i class="fas fa-ban"></i>
                                    </button>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px solid var(--border-color);">
                                <td style="padding: 1rem;"><input type="checkbox"></td>
                                <td style="padding: 1rem;">
                                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                                        <img src="/images/default-avatar.png" style="width: 40px; height: 40px; border-radius: 50%;">
                                        <div>
                                            <strong>Jane Smith</strong>
                                            <div style="font-size: 0.875rem; color: var(--text-secondary);">@janesmith</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="padding: 1rem;">jane@example.com</td>
                                <td style="padding: 1rem;">
                                    <span style="padding: 0.25rem 0.75rem; background: #3b82f6; color: white; border-radius: 12px; font-size: 0.875rem;">
                                        User
                                    </span>
                                </td>
                                <td style="padding: 1rem;">0</td>
                                <td style="padding: 1rem;">
                                    <span style="padding: 0.25rem 0.75rem; background: #10b981; color: white; border-radius: 12px; font-size: 0.875rem;">
                                        Hoạt động
                                    </span>
                                </td>
                                <td style="padding: 1rem;">20/03/2026</td>
                                <td style="padding: 1rem;">
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer;" title="Xem">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer;" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer; color: var(--danger-color);" title="Khóa">
                                        <i class="fas fa-ban"></i>
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color);">
                    <div>Hiển thị 1-20 trong 2,543 người dùng</div>
                    <div style="display: flex; gap: 0.5rem;">
                        <button style="padding: 0.5rem 1rem; border: 1px solid var(--border-color); background: white; border-radius: 6px; cursor: pointer;">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <button style="padding: 0.5rem 1rem; border: 1px solid var(--primary-color); background: var(--primary-color); color: white; border-radius: 6px;">1</button>
                        <button style="padding: 0.5rem 1rem; border: 1px solid var(--border-color); background: white; border-radius: 6px; cursor: pointer;">2</button>
                        <button style="padding: 0.5rem 1rem; border: 1px solid var(--border-color); background: white; border-radius: 6px; cursor: pointer;">3</button>
                        <button style="padding: 0.5rem 1rem; border: 1px solid var(--border-color); background: white; border-radius: 6px; cursor: pointer;">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
            </div>
        </main>
    </div>
</body>
</html>
