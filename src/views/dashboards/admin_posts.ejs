<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý bài viết - Admin</title>
    <link rel="stylesheet" href="/css/dashboard-widgets.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('../../partials/header') %>
    
    <div style="display: flex;">
        <%- include('../../partials/admin-sidebar') %>
        
        <main style="flex: 1; margin-left: 250px; padding: 2rem;">
            <div class="dashboard-container" style="max-width: 100%; margin: 0;">
                <div class="dashboard-header">
            <h1><i class="fas fa-file-alt"></i> Quản lý bài viết</h1>
            <div class="dashboard-actions">
                <button class="btn-icon" title="Thêm bài viết">
                    <i class="fas fa-plus"></i>
                </button>
                <button class="btn-icon" title="Xuất Excel">
                    <i class="fas fa-file-excel"></i>
                </button>
                <button class="btn-icon" title="Làm mới">
                    <i class="fas fa-sync"></i>
                </button>
            </div>
        </div>

        <div class="widgets-grid">
            <!-- Stats -->
            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-file-alt"></i> Tổng bài viết
                    </div>
                </div>
                <div class="stats-value">1,248</div>
                <div class="stats-label">Đã xuất bản</div>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-clock"></i> Chờ duyệt
                    </div>
                </div>
                <div class="stats-value">12</div>
                <div class="stats-label">Cần xem xét</div>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-file"></i> Bản nháp
                    </div>
                </div>
                <div class="stats-value">45</div>
                <div class="stats-label">Chưa hoàn thành</div>
            </div>

            <div class="widget widget-small stats-widget">
                <div class="widget-header">
                    <div class="widget-title">
                        <i class="fas fa-trash"></i> Đã xóa
                    </div>
                </div>
                <div class="stats-value">23</div>
                <div class="stats-label">Trong thùng rác</div>
            </div>

            <!-- Filters & Search -->
            <div class="widget widget-full">
                <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
                    <input type="text" placeholder="Tìm kiếm bài viết..." style="flex: 1; min-width: 300px; padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 8px;">
                    <select style="padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 8px;">
                        <option>Tất cả trạng thái</option>
                        <option>Đã xuất bản</option>
                        <option>Chờ duyệt</option>
                        <option>Bản nháp</option>
                    </select>
                    <select style="padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 8px;">
                        <option>Tất cả danh mục</option>
                        <option>Công nghệ</option>
                        <option>Lập trình</option>
                        <option>Thiết kế</option>
                    </select>
                    <button style="padding: 0.75rem 1.5rem; background: var(--primary-color); color: white; border: none; border-radius: 8px; cursor: pointer;">
                        <i class="fas fa-search"></i> Tìm kiếm
                    </button>
                </div>
            </div>

            <!-- Posts Table -->
            <div class="widget widget-full">
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: var(--bg-secondary); text-align: left;">
                                <th style="padding: 1rem;">
                                    <input type="checkbox">
                                </th>
                                <th style="padding: 1rem;">Tiêu đề</th>
                                <th style="padding: 1rem;">Tác giả</th>
                                <th style="padding: 1rem;">Danh mục</th>
                                <th style="padding: 1rem;">Trạng thái</th>
                                <th style="padding: 1rem;">Lượt xem</th>
                                <th style="padding: 1rem;">Ngày đăng</th>
                                <th style="padding: 1rem;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr style="border-bottom: 1px solid var(--border-color);">
                                <td style="padding: 1rem;"><input type="checkbox"></td>
                                <td style="padding: 1rem;">
                                    <strong>Hướng dẫn Node.js cho người mới</strong>
                                </td>
                                <td style="padding: 1rem;">John Doe</td>
                                <td style="padding: 1rem;">Lập trình</td>
                                <td style="padding: 1rem;">
                                    <span style="padding: 0.25rem 0.75rem; background: #10b981; color: white; border-radius: 12px; font-size: 0.875rem;">
                                        Đã xuất bản
                                    </span>
                                </td>
                                <td style="padding: 1rem;">3,456</td>
                                <td style="padding: 1rem;">25/04/2026</td>
                                <td style="padding: 1rem;">
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer;" title="Xem">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer;" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer; color: var(--danger-color);" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            <tr style="border-bottom: 1px solid var(--border-color);">
                                <td style="padding: 1rem;"><input type="checkbox"></td>
                                <td style="padding: 1rem;">
                                    <strong>React Best Practices 2026</strong>
                                </td>
                                <td style="padding: 1rem;">Jane Smith</td>
                                <td style="padding: 1rem;">Frontend</td>
                                <td style="padding: 1rem;">
                                    <span style="padding: 0.25rem 0.75rem; background: #f59e0b; color: white; border-radius: 12px; font-size: 0.875rem;">
                                        Chờ duyệt
                                    </span>
                                </td>
                                <td style="padding: 1rem;">0</td>
                                <td style="padding: 1rem;">27/04/2026</td>
                                <td style="padding: 1rem;">
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer;" title="Xem">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer;" title="Duyệt">
                                        <i class="fas fa-check"></i>
                                    </button>
                                    <button style="padding: 0.5rem; border: none; background: transparent; cursor: pointer; color: var(--danger-color);" title="Từ chối">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color);">
                    <div>Hiển thị 1-20 trong 1,248 bài viết</div>
                    <div style="display: flex; gap: 0.5rem;">
                        <button style="padding: 0.5rem 1rem; border: 1px solid var(--border-color); background: white; border-radius: 6px; cursor: pointer;">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <button style="padding: 0.5rem 1rem; border: 1px solid var(--primary-color); background: var(--primary-color); color: white; border-radius: 6px;">1</button>
                        <button style="padding: 0.5rem 1rem; border: 1px solid var(--border-color); background: white; border-radius: 6px; cursor: pointer;">2</button>
                        <button style="padding: 0.5rem 1rem; border: 1px solid var(--border-color); background: white; border-radius: 6px; cursor: pointer;">3</button>
                        <button style="padding: 0.5rem 1rem; border: 1px solid var(--border-color); background: white; border-radius: 6px; cursor: pointer;">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
            </div>
        </main>
    </div>
</body>
</html>
