<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cài đặt - <%= siteName %></title>
    <link rel="stylesheet" href="/css/notifications.css">
    <link rel="stylesheet" href="/css/themes.css">
    <link rel="stylesheet" href="/css/language-switcher.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/header') %>
    
    <div class="notifications-container">
        <div class="notifications-header">
            <h1><i class="fas fa-cog"></i> Cài đặt</h1>
        </div>

        <div class="notification-tabs">
            <button class="tab-btn active" data-tab="profile">
                <i class="fas fa-user"></i> Hồ sơ
            </button>
            <button class="tab-btn" data-tab="notifications">
                <i class="fas fa-bell"></i> Thông báo
            </button>
            <button class="tab-btn" data-tab="theme">
                <i class="fas fa-palette"></i> Giao diện
            </button>
            <button class="tab-btn" data-tab="language">
                <i class="fas fa-language"></i> Ngôn ngữ
            </button>
            <button class="tab-btn" data-tab="privacy">
                <i class="fas fa-lock"></i> Quyền riêng tư
            </button>
        </div>

        <div class="notifications-list">
            <div class="settings-section">
                <h3>Thông tin cá nhân</h3>
                <div class="setting-item">
                    <div class="setting-info">
                        <strong>Tên hiển thị</strong>
                        <p>Tên của bạn sẽ hiển thị trên trang cá nhân</p>
                    </div>
                    <input type="text" class="form-control" placeholder="Nhập tên...">
                </div>
                <div class="setting-item">
                    <div class="setting-info">
                        <strong>Email</strong>
                        <p>Email để nhận thông báo và khôi phục tài khoản</p>
                    </div>
                    <input type="email" class="form-control" placeholder="email@example.com">
                </div>
            </div>
        </div>
    </div>

    <script src="/js/notifications.js"></script>
    <script src="/js/theme-switcher.js"></script>
    <script src="/js/language-switcher.js"></script>
</body>
</html>
