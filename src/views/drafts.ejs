<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bản nháp - <%= siteName %></title>
    <link rel="stylesheet" href="/css/draft-autosave.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/header') %>
    
    <div class="draft-editor-container">
        <div class="editor-header">
            <h1>Bản nháp của tôi</h1>
            <div class="autosave-status saved">
                <i class="fas fa-check-circle"></i>
                <span>Đã lưu</span>
            </div>
            <div class="editor-actions">
                <button class="btn btn-secondary">
                    <i class="fas fa-history"></i> Lịch sử phiên bản
                </button>
                <button class="btn btn-primary">
                    <i class="fas fa-plus"></i> Bản nháp mới
                </button>
            </div>
        </div>

        <div class="drafts-list">
            <!-- Draft items will be loaded here -->
        </div>
    </div>

    <script src="/js/draft-autosave.js"></script>
</body>
</html>
