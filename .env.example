# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=my_blog_db

# Server Configuration
PORT=8080
NODE_ENV=development

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# WebSocket Configuration
WS_PORT=8081
WS_PATH=/ws

# Web Push Notifications (Generate: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_SUBJECT=mailto:your@email.com

# Media Upload Configuration
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,application/pdf

# Search Configuration
SEARCH_RESULTS_LIMIT=20
SEARCH_HISTORY_LIMIT=50

# Draft Auto-save Configuration
DRAFT_AUTOSAVE_INTERVAL=30000

# Language Configuration
DEFAULT_LANGUAGE=vi
FALLBACK_LANGUAGE=en
